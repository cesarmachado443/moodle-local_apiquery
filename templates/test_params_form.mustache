{{!
    @template local_apiquery/test_params_form

    Test query - parameter input form.

    @copyright 2026 CESW <cesarmachado443@gmail.com>
    @license http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Context variables required for this template:
    * card_title - Card header text
    * sesskey - Session key
    * params - Array of parameter objects
    * no_params_msg - Message when no parameters declared
    * execute_btn - Execute button text

    Example context (json):
    {
        "card_title": "Test Parameters",
        "sesskey": "abc123",
        "params": [
            {
                "name": "since",
                "type": "int",
                "required": true,
                "default": "1738000000",
                "value": "",
                "required_label": "Required",
                "default_text": "default: 1738000000"
            }
        ],
        "execute_btn": "Execute Query"
    }
}}
<div class="card mb-4">
    <div class="card-header fw-bold">{{card_title}}</div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" name="sesskey" value="{{sesskey}}">

            {{#has_params}}
                {{#params}}
                <div class="mb-3 row align-items-center">
                    <label class="col-sm-3 col-form-label fw-semibold">
                        <code>:{{name}}</code>
                        <span class="badge bg-light text-dark ms-1">{{type}}</span>
                        {{#required}}
                        <span class="text-danger">*</span>
                        {{/required}}
                    </label>
                    <div class="col-sm-5">
                        <input type="text" name="tp_{{name}}"
                               class="form-control"
                               value="{{value}}"
                               placeholder="{{default}}">
                    </div>
                    <div class="col-sm-4 text-muted small">
                        {{required_label}}
                        {{#default_text}} · {{default_text}}{{/default_text}}
                    </div>
                </div>
                {{/params}}
            {{/has_params}}

            {{^has_params}}
            <p class="text-muted">{{no_params_msg}}</p>
            {{/has_params}}

            <button type="submit" class="btn btn-primary">{{execute_btn}}</button>
        </form>
    </div>
</div>
