<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/apiquery/db" VERSION="20260407" COMMENT="Database tables for SQL queries configured via admin UI">
  <TABLES>
    <TABLE NAME="local_apiquery_queries" COMMENT="SQL queries configured by administrators">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="shortname"    TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="displayname"  TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="description"  TYPE="text" NOTNULL="false"/>
        <FIELD NAME="sqlquery"     TYPE="text" NOTNULL="true"/>
        <FIELD NAME="parameters"   TYPE="text" NOTNULL="false"/>
        <FIELD NAME="enabled"      TYPE="int"  LENGTH="1"  NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="timecreated"  TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="createdby"    TYPE="int"  LENGTH="10" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="shortname_unique" TYPE="unique" FIELDS="shortname"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="enabled_idx" UNIQUE="false" FIELDS="enabled"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_apiquery_logs" COMMENT="Execution logs of queries called via API">
      <FIELDS>
        <FIELD NAME="id"            TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="query_id"      TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid"        TYPE="int"  LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="params_used"   TYPE="text" NOTNULL="false"/>
        <FIELD NAME="rows_returned" TYPE="int"  LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="execution_ms"  TYPE="int"  LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timecreated"   TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="error"         TYPE="text" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="query_id_fk" TYPE="foreign" FIELDS="query_id" REFTABLE="local_apiquery_queries" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="timecreated_idx" UNIQUE="false" FIELDS="timecreated"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
